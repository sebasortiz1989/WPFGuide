<Window
    Height="450"
    Title="MainWindow"
    Width="800"
    mc:Ignorable="d"
    x:Class="ToolbarDemo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ToolbarDemo"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar Margin="0,10,0,-10">
                <Button Click="Button_Click" ToolTip="Delete Text of File">
                    Delete Text
                </Button>
                <Separator />
                <Label>Font Size</Label>
                <ComboBox Name="cb1" SelectionChanged="ComboBox_SelectionChanged">
                    <ComboBoxItem>8</ComboBoxItem>
                    <ComboBoxItem IsSelected="True">10</ComboBoxItem>
                    <ComboBoxItem>12</ComboBoxItem>
                    <ComboBoxItem>14</ComboBoxItem>
                </ComboBox>
            </ToolBar>
        </ToolBarTray>
        <TextBox
            Margin="0,37,0,30"
            Width="776"
            x:Name="myTextbox" />
    </DockPanel>
</Window>
