<Window
    Height="350"
    Title="MainWindow"
    Width="250  "
    mc:Ignorable="d"
    x:Class="TextBlockDemo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TextBlockDemo"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>

        <TextBlock>
            Hello<Bold>World!</Bold>
            And Hello<Italic>you</Italic>
            <LineBreak />
            Go To<Hyperlink NavigateUri="https://www.google.com" RequestNavigate="Hyperlink_RequestNavigate">google.com</Hyperlink>
        </TextBlock>

        <TextBlock />

        <TextBlock
            Foreground="Red"
            TextWrapping="Wrap"
            x:Name="myTextBlock">
            Lorem ipsum<Span Foreground="Black">dolor sit amet</Span>
            ,
            consectetur adipiscing elit.
            Proin non gravida nulla, a rutrum quam. Phasellus ullamcorper
            ante nisl, sed ornare odio tincidunt ut. Pellentesque vitae
            lobortis risus. Donec suscipit mauris vitae velit convallis
            mattis vitae eu velit. Sed et maximus velit. Nunc ut turpis laoreet,
            iaculis quam quis, sollicitudin mauris. Vestibulum pretium leo ipsum,
            a ornare dolor fermentum at. Nunc ut condimentum est, quis consectetur arcu.
            Vestibulum non lacus ut lacus aliquet egestas vitae at justo. Nulla ac porta
            metus, nec fringilla erat.</TextBlock>

    </StackPanel>
</Window>
