<Window
    Height="450"
    Title="MainWindow"
    Width="800"
    mc:Ignorable="d"
    x:Class="CatYearsProject.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:CatYearsProject"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Orientation="Vertical">
        <StackPanel Orientation="Horizontal">
            <TextBlock FontSize="18" Text="How old is your dog? (years)" />
            <TextBox
                FontSize="16"
                KeyDown="ResultTextBlock_KeyDown"
                Margin="5,0,0,0"
                TextAlignment="Center"
                Width="120"
                x:Name="InputDogAge" />
        </StackPanel>
        <Button Click="ButtonBase_OnClick">Button2</Button>
        <TextBlock
            FontSize="18"
            Name="ResultTextBlock"
            Text="Your dog is" />
        <Image
            Height="350"
            Margin="10,15,10,0"
            Source="https://www.foresightsports.com/sites/default/files/images/home/play-anywhere.jpg" />
    </StackPanel>
</Window>
