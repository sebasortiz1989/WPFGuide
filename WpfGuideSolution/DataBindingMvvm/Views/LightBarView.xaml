    <Viewbox>
        <Grid
            Background="Black"
            Height="800"
            Width="1280">
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="736" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <Grid Grid.Row="0">
                <StackPanel
                    HorizontalAlignment="Left"
                    Margin="15,0,0,0"
                    Orientation="Horizontal">
                    <Border
                        Background="White"
                        BorderBrush="#93989E"
                        BorderThickness="0.5"
                        CornerRadius="2"
                        Height="24"
                        Width="24">
                        <Viewbox
                            HorizontalAlignment="Center"
                            Margin="0,0,1,1"
                            VerticalAlignment="Center">
                            <Path
                                Data="{DynamicResource logoVerion}"
                                Fill="#F6A500"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Viewbox>
                    </Border>

                    <Viewbox
                        Height="24"
                        HorizontalAlignment="Left"
                        Margin="-28,0,0,0"
                        VerticalAlignment="Center">
                        <Path Data="{DynamicResource nameVerion}" Fill="#FC1D2F" />
                    </Viewbox>

                </StackPanel>
                <TextBlock
                    FontSize="32"
                    FontWeight="600"
                    Foreground="#5CC4E6"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    Light Bar
                </TextBlock>
                <Border BorderThickness="0,0,0,1" Grid.ColumnSpan="3">
                    <Border.BorderBrush>
                        <LinearGradientBrush EndPoint="1,0.5" StartPoint="0,0.5">
                            <GradientStop Color="Transparent" Offset="0" />
                            <GradientStop Color="#43B6DB" Offset="0.5" />
                            <GradientStop Color="Transparent" Offset="1" />
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                </Border>
            </Grid>

            <!--  Content  -->
            <StackPanel Grid.Row="1">
                <Image
                    Margin="0,54,0,0"
                    Source="pack://application:,,,/images/BarraDeLuz2.png"
                    Width="717" />

                <Grid HorizontalAlignment="Center" Width="310">
                    <TextBlock
                        FontSize="32"
                        FontWeight="600"
                        Foreground="#5DE4FF"
                        HorizontalAlignment="Left"
                        TextAlignment="Center">
                        <Run Text="{Binding DistanceBetweenPointsLightBar}" />
                        <Run Text="cm" />
                    </TextBlock>
                    <TextBlock
                        FontSize="32"
                        FontWeight="600"
                        Foreground="#5DE4FF"
                        HorizontalAlignment="Center"
                        Text="0"
                        TextAlignment="Center" />
                    <TextBlock
                        FontSize="32"
                        FontWeight="600"
                        Foreground="#5DE4FF"
                        HorizontalAlignment="Right"
                        TextAlignment="Center">
                        <Run Text="{Binding DistanceBetweenPointsLightBar}" />
                        <Run Text="cm" />
                    </TextBlock>
                </Grid>

                <Border
                    BorderThickness="0,0,0,3"
                    Margin="0,25,0,0"
                    Width="250">
                    <Border.BorderBrush>
                        <LinearGradientBrush EndPoint="1,0.5" StartPoint="0,0.5">
                            <GradientStop Color="Transparent" Offset="0" />
                            <GradientStop Color="#43B6DB" Offset="0.5" />
                            <GradientStop Color="Transparent" Offset="1" />
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                </Border>

                <TextBlock
                    FontSize="32"
                    FontWeight="600"
                    Foreground="#5CC4E6"
                    HorizontalAlignment="Center"
                    Margin="0,25,0,0"
                    VerticalAlignment="Center">
                    Bar Configuration
                </TextBlock>

                <Grid Margin="0,32,0,0" Width="962">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="63" />
                        <RowDefinition Height="67" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="481" />
                        <ColumnDefinition Width="481" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        FontSize="32"
                        FontWeight="600"
                        Foreground="White"
                        Grid.Column="0"
                        Grid.Row="0"
                        HorizontalAlignment="Left"
                        Text="Distance Between Leds" />

                    <components:BorderedNumericIntTextBox
                        Background="Black"
                        BorderBrush="#43B6DB"
                        BorderThickness="4"
                        CornerRadius="8"
                        FontSize="32"
                        FontWeight="600"
                        Foreground="White"
                        Grid.Column="0"
                        Grid.Row="1"
                        Height="67"
                        HorizontalAlignment="Left"
                        HorizontalContentAlignment="Center"
                        Text="{Binding DistanceBetweenPointsLightBar, UpdateSourceTrigger=PropertyChanged}"
                        VerticalContentAlignment="Center"
                        Width="393" />

                    <Border
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Stretch"
                        Width="3">
                        <Border.Background>
                            <LinearGradientBrush EndPoint="0,1" StartPoint="0,0">
                                <GradientStop Color="Transparent" Offset="0" />
                                <GradientStop Color="#43B6DB" Offset="0.5" />
                                <GradientStop Color="Transparent" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <TextBlock
                        FontSize="32"
                        FontWeight="600"
                        Foreground="White"
                        Grid.Column="1"
                        Grid.Row="0"
                        HorizontalAlignment="Right"
                        Text="Alignment Distance" />

                    <components:BorderedNumericIntTextBox
                        Background="Black"
                        BorderBrush="#43B6DB"
                        BorderThickness="4"
                        CornerRadius="8"
                        FontSize="32"
                        FontWeight="600"
                        Foreground="White"
                        Grid.Column="1"
                        Grid.Row="1"
                        Height="67"
                        HorizontalAlignment="Right"
                        HorizontalContentAlignment="Center"
                        Text="{Binding DistanceAlignmentLightBar, UpdateSourceTrigger=PropertyChanged}"
                        VerticalContentAlignment="Center"
                        Width="393" />
                </Grid>
            </StackPanel>

            <components:BorderedButton
                Background="Black"
                BorderBrush="#43B6DB"
                BorderThickness="4"
                CornerRadius="35"
                FontSize="32"
                FontWeight="600"
                Foreground="#43B6DB"
                Grid.Row="1"
                Height="67"
                HorizontalAlignment="Left"
                HorizontalContentAlignment="Center"
                HoverBackground="#4D43B6DB"
                HoverBorderBrush="#43B6DB"
                HoverForeground="#43B6DB"
                Margin="40"
                PressedBackground="#43B6DB"
                PressedBorderBrush="#43B6DB"
                PressedForeground="Black"
                Text="Back"
                VerticalAlignment="Bottom"
                VerticalContentAlignment="Center"
                Width="200" />

            <components:BorderedButton
                Background="Black"
                BorderBrush="#43B6DB"
                BorderThickness="4"
                CornerRadius="35"
                FontSize="32"
                FontWeight="600"
                Foreground="#43B6DB"
                Grid.Row="1"
                Height="67"
                HorizontalAlignment="Right"
                HorizontalContentAlignment="Center"
                HoverBackground="#4D43B6DB"
                HoverBorderBrush="#43B6DB"
                HoverForeground="#43B6DB"
                IsEnabled="False"
                Margin="40"
                PressedBackground="#43B6DB"
                PressedBorderBrush="#43B6DB"
                PressedForeground="Black"
                Text="Save"
                VerticalAlignment="Bottom"
                VerticalContentAlignment="Center"
                Width="200" />

        </Grid>
    </Viewbox>

</UserControl>
